{
  "compilerOptions": {
    // ========= ОСНОВНЫЕ =========
    "target": "ES2022",
"lib": ["dom", "dom.iterable", "ES2022"],
    "module": "esnext",
"moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "jsx": "preserve",

    // ========= УДОБСТВА =========
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    // ========= ПУТИ =========
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "components/chat/ChatPage.tsx",
    "components/chat/ChatList.tsx",
    "pages/chat/[id].js"
  ],

  "exclude": [
    "node_modules",
    "korshi-ocr-worker",
    "korshi-ocr-worker/**"
  ]
}